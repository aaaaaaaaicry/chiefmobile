-- Aplica Chams normal
local function ApplyChamsToCharacter(character)
    if not character or not Chams.Enabled then return end
    
    local chamsData = {
        originalMaterials = {},
        originalTransparency = {},
        originalColor = {},
        highlights = {}
    }
    
    for _, part in pairs(character:GetDescendants()) do
        if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
            chamsData.originalMaterials[part] = part.Material
            chamsData.originalTransparency[part] = part.Transparency
            chamsData.originalColor[part] = part.Color
            
            part.Material = GetMaterialEnum(Chams.Material)
            part.Transparency = 0
            part.LocalTransparencyModifier = Chams.Transparency
            part.Color = Chams.Color
            
            if Chams.Wallhack then
                local highlight = Instance.new("Highlight")
                highlight.FillTransparency = math.clamp(Chams.Transparency, 0.2, 0.8)
                highlight.OutlineTransparency = math.clamp(1 - Chams.Transparency, 0, 1)
                highlight.OutlineColor = Chams.Color
                highlight.FillColor = Chams.Color
                highlight.Parent = part
                table.insert(chamsData.highlights, highlight)
            end
        end
    end
    
    Chams.ChamsObjects[character] = chamsData
end

-- Aplica Mini Chams (sem textura - corpo normal)
local function ApplyMiniChamsToCharacter(character)
    if not character or not Chams.Enabled or not Chams.MiniMode then return end
    
    local miniData = {
        highlights = {}
    }
    
    for _, part in pairs(character:GetDescendants()) do
        if part:IsA("BasePart") then
            if Chams.Wallhack then
                local highlight = Instance.new("Highlight")
                highlight.FillTransparency = math.clamp(Chams.Transparency, 0.2, 0.8)
                highlight.OutlineTransparency = 1
                highlight.FillColor = part.Color
                highlight.Parent = part
                table.insert(miniData.highlights, highlight)
            end
        end
    end
    
    MiniChams.MiniChamsObjects[character] = miniData
end

-- Remove Chams normal
local function RemoveChamsFromCharacter(character)
    local chamsData = Chams.ChamsObjects[character]
    if chamsData then
        for part, originalMat in pairs(chamsData.originalMaterials) do
            if part and part.Parent then
                part.Material = originalMat
                part.Transparency = chamsData.originalTransparency[part] or 0
                part.LocalTransparencyModifier = 0
                part.Color = chamsData.originalColor[part] or Color3.fromRGB(255, 255, 255)
            end
        end
        for _, highlight in pairs(chamsData.highlights) do
            if highlight then highlight:Destroy() end
        end
        Chams.ChamsObjects[character] = nil
    end
end

local function UpdateChamsTransparency()
    for _, data in pairs(Chams.ChamsObjects) do
        for part, _ in pairs(data.originalMaterials) do
            if part and part.Parent then
                part.Transparency = 0
                part.LocalTransparencyModifier = Chams.Transparency
            end
        end

        for _, highlight in pairs(data.highlights) do
            if highlight and highlight.Parent then
                highlight.FillTransparency = math.clamp(Chams.Transparency, 0.2, 0.8)
                highlight.OutlineTransparency = math.clamp(1 - Chams.Transparency, 0, 1)
            end
        end
    end

    for _, data in pairs(MiniChams.MiniChamsObjects) do
        for _, highlight in pairs(data.highlights) do
            if highlight and highlight.Parent then
                highlight.FillTransparency = math.clamp(Chams.Transparency, 0.2, 0.8)
            end
        end
    end
end

-- Remove Mini Chams
local function RemoveMiniChamsFromCharacter(character)
    local miniData = MiniChams.MiniChamsObjects[character]
    if miniData then
        for _, highlight in pairs(miniData.highlights) do
            if highlight then
                highlight:Destroy()
            end
        end
        MiniChams.MiniChamsObjects[character] = nil
    end
end

-- Atualiza todos os players
local function RefreshAllEffects()
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= player and plr.Character then
            RemoveChamsFromCharacter(plr.Character)
            RemoveMiniChamsFromCharacter(plr.Character)
            
            if Chams.Enabled then
                if Chams.MiniMode then
                    ApplyMiniChamsToCharacter(plr.Character)
                else
                    ApplyChamsToCharacter(plr.Character)
                end
            end
        end
    end
end

