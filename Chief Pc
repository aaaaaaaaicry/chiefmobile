    local function DrawSkeleton(character, data, distance)
        if not character or not esp_flags["Enabled"] or not esp_flags["Skeletons"] then 
            if data then
                HideDrawings(data)
            end
            return 
        end
        
        if distance > esp_flags["MaxDistance"] then
            if data then
                HideDrawings(data)
            end
            return
        end
        
        local bonesList = GetBonesForCharacter(character)
        
        for i, bone in ipairs(bonesList) do
            local originPart = character:FindFirstChild(bone[1])
            local destPart = character:FindFirstChild(bone[2])
            
            if originPart and destPart then
                if not data.drawings[i] then
                    local line = Drawing.new("Line")
                    line.Color = esp_flags["Skeletons_Color"].Color
                    line.Thickness = 1
                    line.Visible = false
                    data.drawings[i] = line
                end
                
                local originPos, originOnScreen = esp:get_screen_pos(originPart.Position)
                local destPos, destOnScreen = esp:get_screen_pos(destPart.Position)
                
                if originOnScreen and destOnScreen then
                    data.drawings[i].Visible = true
                    data.drawings[i].From = Vector2.new(originPos.X, originPos.Y)
                    data.drawings[i].To = Vector2.new(destPos.X, destPos.Y)
                    data.drawings[i].Color = esp_flags["Skeletons_Color"].Color
                else
                    data.drawings[i].Visible = false
                end
            end
        end
    end

    esp.connection = run.RenderStepped:Connect(function()
        if not esp_flags["Enabled"] then 
            for _, esp_player in players_service:GetPlayers() do 
                if esp_player ~= players_service.LocalPlayer then
                    local data = esp[esp_player.Name]
                    if data then
                        HideDrawings(data)
                        if data.objects and data.objects.holder then
                            data.objects.holder.Visible = false
                        end
                    end
                end
            end
            return
        end

        for _, esp_player in players_service:GetPlayers() do 
            if esp_player == players_service.LocalPlayer then
                continue
            end
            
            if esp_flags["TeamCheck"] and esp_player.Team == player.Team then
                local data = esp[esp_player.Name]
                if data then
                    HideDrawings(data)
                    if data.objects and data.objects.holder then
                        data.objects.holder.Visible = false
                    end
                end
                continue
            end
            
            local data = esp[esp_player.Name]

            if not data then 
                continue 
            end 

            local character = data.info.character
            local humanoid = data.info.humanoid 
            
            if not (character and humanoid) then 
                continue 
            end 

            local objects = data and data.objects 

            if not objects then 
                continue 
            end 

            local rootPart = humanoid.RootPart
            if not rootPart then continue end
            
            local box_size, box_pos, on_screen, distance = esp:box_solve(rootPart)
            
            DrawSkeleton(character, data, distance)
            
            if distance > esp_flags["MaxDistance"] then
                if objects.holder.Visible then
                    objects.holder.Visible = false
                    HideDrawings(data)
                end
                continue
            end
            
            local holder = objects[ "holder" ]

            if holder.Visible ~= on_screen then 
                holder.Visible = on_screen
            end 

            if not on_screen then
                continue
            end 
            
            local pos = dim_offset(box_pos.X, box_pos.Y)
            if pos ~= holder.Position then 
                holder.Position = dim_offset(box_pos.X, box_pos.Y)
            end 

            local size = dim_offset(box_size.X, box_size.Y)
            if size ~= holder.Size then 
                holder.Size = size
            end 

            local distance_label = objects[ "distance" ]
            if distance_label.Text ~= tostring( math.round(distance) ) .. "st" then 
                distance_label.Text = tostring( math.round(distance) ) .. "st"
            end 
        end
    end)

    function esp:unload() 
        for _, esp_player in players_service:GetPlayers() do 
            local data = esp[esp_player.Name]
            if data then
                ClearDrawings(data)
            end
            esp:remove_object(esp_player)
        end 

        esp.connection:Disconnect() 
        if esp.player_added then esp.player_added:Disconnect() end
        if esp.player_removed then esp.player_removed:Disconnect() end

        esp.cache:Destroy() 
        esp.screengui:Destroy()
    end 
end

