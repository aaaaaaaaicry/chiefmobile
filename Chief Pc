local function SetInvisible(char, state)
    if not char then return end
    
    for _, v in pairs(char:GetDescendants()) do
        if v:IsA("BasePart") then
            v.LocalTransparencyModifier = state and 1 or 0
        elseif v:IsA("Decal") then
            v.Transparency = state and 1 or 0
        end
    end
end

local function GetMagnetHitboxPart(character, hitboxName)
    if not character then return nil end
    
    if hitboxName == "Random" then
        return GetRandomHitbox(character)
    end
    
    if hitboxName == "Head" then
        return character:FindFirstChild("Head")
    elseif hitboxName == "UpperTorso" then
        local part = character:FindFirstChild("UpperTorso")
        if not part then
            part = character:FindFirstChild("Torso")
        end
        return part
    elseif hitboxName == "HumanoidRootPart" then
        return character:FindFirstChild("HumanoidRootPart")
    end
    return character:FindFirstChild("HumanoidRootPart")
end

local function AddGhostTarget(character)
    if not character or not MagnetAim.GhostMode then return end
    
    for i, target in pairs(MagnetAim.CurrentGhostTargets) do
        if target == character then
            return
        end
    end
    
    table.insert(MagnetAim.CurrentGhostTargets, character)
    SetInvisible(character, true)
end

local function RemoveGhostTarget(character)
    for i, target in pairs(MagnetAim.CurrentGhostTargets) do
        if target == character then
            SetInvisible(character, false)
            table.remove(MagnetAim.CurrentGhostTargets, i)
            break
        end
    end
end

local function RemoveAllGhosts()
    for _, target in pairs(MagnetAim.CurrentGhostTargets) do
        SetInvisible(target, false)
    end
    MagnetAim.CurrentGhostTargets = {}
end

local function GetClosestPlayerToCursor()
    local closest = nil
    local distMin = MagnetAim.Range
    local mousePos = UserInputService:GetMouseLocation()
    local allTargets = {}
    
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= player and plr.Character then
            if MagnetAim.TeamCheck and plr.Team == player.Team then
                continue
            end
            
            local humanoid = plr.Character:FindFirstChildOfClass("Humanoid")
            if humanoid and humanoid.Health <= 0 then
                continue
            end
            
            local hitboxPart = GetMagnetHitboxPart(plr.Character, MagnetAim.Hitbox)
            if hitboxPart then
                local pos, vis = Camera:WorldToViewportPoint(hitboxPart.Position)
                
                if vis then
                    local dist = (Vector2.new(pos.X, pos.Y) - mousePos).Magnitude
                    if dist < distMin then
                        distMin = dist
                        closest = plr
                    end
                    table.insert(allTargets, plr)
                end
            end
        end
    end
    
    if MagnetAim.GhostMode then
        for i = #MagnetAim.CurrentGhostTargets, 1, -1 do
            local ghostChar = MagnetAim.CurrentGhostTargets[i]
            local stillInRange = false
            
            for _, plr in pairs(allTargets) do
                if plr.Character == ghostChar then
                    stillInRange = true
                    break
                end
            end
            
            if not stillInRange then
                RemoveGhostTarget(ghostChar)
            end
        end
    end
    
    return closest
end

local function MagnetPullPlayer(target)
    if not target or not target.Character then return end
    
    local part = GetMagnetHitboxPart(target.Character, MagnetAim.Hitbox)
    if not part then return end
    
    local mousePos = UserInputService:GetMouseLocation()
    local ray = Camera:ViewportPointToRay(mousePos.X, mousePos.Y)
    local newPos = ray.Origin + ray.Direction * 10
    
