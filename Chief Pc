local function GetValidTargetAtMouse()
    local mousePos = GetMousePosition()
    local closestPart = nil
    local closestDistance = 50
    local cameraPos = Camera.CFrame.Position
    
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= player then
            if TriggerBot.TeamCheck and plr.Team == player.Team then
                continue
            end
            
            local char = plr.Character
            if not char then continue end
            if not IsAlive(char) then continue end
            
            local hitboxPart = GetHitboxPart(char, AimAssist.Hitbox)
            
            if hitboxPart then
                local pos, onScreen = Camera:WorldToViewportPoint(hitboxPart.Position)
                if onScreen then
                    local distanceToMouse = (Vector2.new(pos.X, pos.Y) - mousePos).Magnitude
                    
                    if distanceToMouse < closestDistance then
                        if CanSeeTarget(cameraPos, hitboxPart) then
                            closestDistance = distanceToMouse
                            closestPart = hitboxPart
                        end
                    end
                end
            end
        end
    end
    
    return closestPart
end

local function GetBestTargetInFOV()
    local mousePos = UserInputService:GetMouseLocation()
    local cameraPos = Camera.CFrame.Position
    
    local bestChar = nil
    local bestPart = nil
    local bestDistance = AimAssist.FOV
    
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= player then
            if TriggerBot.TeamCheck and plr.Team == player.Team then
                continue
            end
            
            local char = plr.Character
            if not char then continue end
            if not IsAlive(char) then continue end
            
            local hitboxPart = GetHitboxPart(char, AimAssist.Hitbox)
            
            if hitboxPart then
                local screenPos, onScreen = Camera:WorldToViewportPoint(hitboxPart.Position)
                if onScreen then
                    local distanceFromMouse = (Vector2.new(screenPos.X, screenPos.Y) - mousePos).Magnitude
                    
                    if distanceFromMouse < bestDistance then
                        if CanSeeTarget(cameraPos, hitboxPart) then
                            bestDistance = distanceFromMouse
                            bestChar = char
                            bestPart = hitboxPart
                        end
                    end
                end
            end
        end
    end
    
    return bestChar, bestPart
end

