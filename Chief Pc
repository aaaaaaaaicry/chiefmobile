    local keyPressed = input.KeyCode.Name
    local mouseButton = input.UserInputType
    
    local isKeyMatch = false
    if MagnetAim.Key == "MB1" and mouseButton == Enum.UserInputType.MouseButton1 then
        isKeyMatch = true
    elseif MagnetAim.Key == "MB2" and mouseButton == Enum.UserInputType.MouseButton2 then
        isKeyMatch = true
    elseif MagnetAim.Key == "MB3" and mouseButton == Enum.UserInputType.MouseButton3 then
        isKeyMatch = true
    elseif keyPressed == MagnetAim.Key then
        isKeyMatch = true
    end
    
    if isKeyMatch then
        if MagnetAim.Mode == "hold" then
            MagnetAim.Holding = true
            
            if MagnetAim.GhostMode then
                local target = GetClosestPlayerToCursor()
                if target and target.Character then
                    MagnetAim.CurrentGhostTarget = target.Character
                    SetInvisible(MagnetAim.CurrentGhostTarget, true)
                end
            end
        else
            if not MagnetAim.ToggleState then
                MagnetAim.ToggleState = true
                MagnetAim.Holding = true
                
                if MagnetAim.GhostMode then
                    local target = GetClosestPlayerToCursor()
                    if target and target.Character then
                        MagnetAim.CurrentGhostTarget = target.Character
                        SetInvisible(MagnetAim.CurrentGhostTarget, true)
                    end
                end
            else
                MagnetAim.ToggleState = false
                MagnetAim.Holding = false
                
                if MagnetAim.GhostMode then
                    RemoveGhost()
                end
            end
        end
    end
end)

