-- ========== FUNÇÕES DO RAGE BOT ==========
local function GetRageTargetInFOV()
    local mousePos = UserInputService:GetMouseLocation()
    local cameraPos = Camera.CFrame.Position
    
    local bestChar = nil
    local bestPart = nil
    local bestDistance = RageBot.FOV
    
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= player then
            if RageBot.TeamCheck and plr.Team == player.Team then
                continue
            end
            
            local char = plr.Character
            if not char then continue end
            
            local humanoid = char:FindFirstChildOfClass("Humanoid")
            if not humanoid or humanoid.Health <= 0 then continue end
            
            local hitboxPart = GetHitboxPart(char, RageBot.Hitbox)
            
            if hitboxPart then
                local screenPos, onScreen = Camera:WorldToViewportPoint(hitboxPart.Position)
                
                if onScreen then
                    if RageBot.VisibleCheck then
                        local raycastParams = RaycastParams.new()
                        raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
                        raycastParams.FilterDescendantsInstances = {player.Character}
                        local rayResult = workspace:Raycast(cameraPos, (hitboxPart.Position - cameraPos), raycastParams)
                        if rayResult and not rayResult.Instance:IsDescendantOf(char) then
                            continue
                        end
                    end
                    
                    local distanceFromMouse = (Vector2.new(screenPos.X, screenPos.Y) - mousePos).Magnitude
                    
                    if distanceFromMouse < bestDistance then
                        bestDistance = distanceFromMouse
                        bestChar = char
                        bestPart = hitboxPart
                    end
                end
            end
        end
    end
    
    return bestChar, bestPart
end

local function LockRageTarget()
    local targetChar, targetPart = GetRageTargetInFOV()
    if targetChar and targetPart then
        RageBot.LockedCharacter = targetChar
        RageBot.LockedPart = targetPart
        return true
    end
    return false
end

local function ResetRageLock()
    RageBot.LockedCharacter = nil
    RageBot.LockedPart = nil
end

local function UpdateRageLockedPart()
    if not RageBot.LockedCharacter then return end
    local newPart = GetHitboxPart(RageBot.LockedCharacter, RageBot.Hitbox)
    if newPart then
        RageBot.LockedPart = newPart
    end
end

local function RageAimAtTarget()
    if not RageBot.LockedCharacter or not RageBot.LockedPart then return end
    
    if not RageBot.LockedPart.Parent then
        UpdateRageLockedPart()
        if not RageBot.LockedPart then
            ResetRageLock()
            if RageBot.Mode == "toggle" then
                RageBot.ToggleState = false
            end
            return
        end
    end
    
    local char = RageBot.LockedCharacter
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not humanoid or humanoid.Health <= 0 then
        ResetRageLock()
        if RageBot.Mode == "toggle" then
            RageBot.ToggleState = false
        end
        return
    end
    
    local screenPos, onScreen = Camera:WorldToViewportPoint(RageBot.LockedPart.Position)
    if not onScreen then return end
    
    local mousePos = UserInputService:GetMouseLocation()
    
    local deltaX = screenPos.X - mousePos.X
    local deltaY = screenPos.Y - mousePos.Y
    
    if math.abs(deltaX) < 0.8 and math.abs(deltaY) < 0.8 then
        return
    end
    
    local strength = 0.85
    local moveX = deltaX * strength
    local moveY = deltaY * strength
    
    if math.abs(moveX) > 0.1 or math.abs(moveY) > 0.1 then
        mousemoverel(moveX, moveY)
    end
end

-- Função que decide se o Rage deve ativar (com While Aiming)
local function ShouldRage()
    if not RageBot.Enabled then 
        return false 
    end
    
    -- SE WHILE AIMING ESTIVER ATIVADO: só rage se estiver mirando (botão direito)
    if RageBot.WhileAiming then
        -- Se NÃO está mirando, NUNCA ativa
        if not IsAiming() then
            -- Limpa o lock se tiver
            if RageBot.LockedCharacter then
                ResetRageLock()
            end
            return false
        end
        
        -- Está mirando! Tenta achar alvo se não tiver
        if not RageBot.LockedCharacter then
            LockRageTarget()
        end
        
        return RageBot.LockedCharacter ~= nil
    end
    
    -- MODO NORMAL (sem while aiming)
    if RageBot.Mode == "hold" then
        return RageBot.LockedCharacter ~= nil
    else
        return RageBot.ToggleState
    end
end

-- ========== FUNÇÕES DE MOVIMENTO ==========
local function StartCFrameSpeed()
    if not CFrameSpeed.Enabled or not CFrameSpeed.Holding then return end
    
    local char = player.Character
    if not char then return end
    
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    local rootPart = char:FindFirstChild("HumanoidRootPart")
    
    if humanoid and rootPart and humanoid.MoveDirection.Magnitude > 0 then
        rootPart.CFrame = rootPart.CFrame + (humanoid.MoveDirection * CFrameSpeed.Speed)
    end
end

local function StartBHop()
    if not BHop.Enabled then return end
    
    local char = player.Character
    if not char then return end
    
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end
    
    local now = tick()
    if now - BHop.LastJump > 0.2 and humanoid.FloorMaterial ~= Enum.Material.Air then
        humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
        BHop.LastJump = now
    end
end

local function ApplyJumpPower()
    local char = player.Character
    if not char then return end
    
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if humanoid then
        humanoid.JumpPower = JumpPower.Power
    end
end

local function RemoveJumpPower()
    local char = player.Character
    if not char then return end
    
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if humanoid then
        humanoid.JumpPower = 50
    end
end

