local function GetHitboxPart(character, hitboxName)
    if not character then return nil end
    
    if hitboxName == "Head" then
        return character:FindFirstChild("Head")
    elseif hitboxName == "UpperTorso" then
        local part = character:FindFirstChild("UpperTorso")
        if not part then
            part = character:FindFirstChild("Torso")
        end
        return part
    end
    return nil
end

local function CanSeeTarget(origin, targetPart)
    if not targetPart then return false end
    if not TriggerBot.WallCheck then return true end
    
    local raycastParams = RaycastParams.new()
    raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
    raycastParams.FilterDescendantsInstances = {player.Character, Camera}
    
    local direction = (targetPart.Position - origin).Unit
    local distance = (targetPart.Position - origin).Magnitude
    local rayResult = workspace:Raycast(origin, direction * distance, raycastParams)
    
    if rayResult then
        local hit = rayResult.Instance
        if hit:IsDescendantOf(targetPart.Parent) then
            return true
        end
        return false
    end
    
    return true
end

