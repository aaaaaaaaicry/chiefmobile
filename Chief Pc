local function stopFly()
    if not FlySystem.flying then return end
    FlySystem.flying = false
    
    if FlySystem.flyKeyDown then FlySystem.flyKeyDown:Disconnect() end
    if FlySystem.flyKeyUp then FlySystem.flyKeyUp:Disconnect() end
    if FlySystem.flyConnection then FlySystem.flyConnection:Disconnect() end
    
