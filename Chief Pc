        if TriggerBot.Enabled and TriggerBot.IsActive then
            local target = GetValidTargetAtMouse()
            if target then
                if TriggerBot.ShootMode == "click" then
                    ClickShoot()
                    task.wait(0.05)
                else
                    StartHold()
                end
            else
                if TriggerBot.ShootMode == "hold" then
                    StopHold()
                end
            end
        elseif TriggerBot.ShootMode == "hold" then
            StopHold()
        end
    end
end)

RunService.RenderStepped:Connect(function()
    if AimAssist.FOVCircle and AimAssist.ShowFOVCircle and AimAssist.Enabled then
        local mousePos = UserInputService:GetMouseLocation()
        AimAssist.FOVCircle.Position = Vector2.new(mousePos.X, mousePos.Y)
        AimAssist.FOVCircle.Radius = AimAssist.FOV
        AimAssist.FOVCircle.Visible = true
    elseif AimAssist.FOVCircle then
        AimAssist.FOVCircle.Visible = false
    end
    
    if RageBot.FOVCircle and RageBot.ShowFOVCircle and RageBot.Enabled then
        local mousePos = UserInputService:GetMouseLocation()
        RageBot.FOVCircle.Position = Vector2.new(mousePos.X, mousePos.Y)
        RageBot.FOVCircle.Radius = RageBot.FOV
        RageBot.FOVCircle.Visible = true
    elseif RageBot.FOVCircle then
        RageBot.FOVCircle.Visible = false
    end
    
    if MagnetAim.Circle and MagnetAim.CircleVisible and MagnetAim.Enabled then
        local mousePos = UserInputService:GetMouseLocation()
        MagnetAim.Circle.Position = Vector2.new(mousePos.X, mousePos.Y)
    end
    
    if AimAssist.Enabled then
        local shouldAim = false
        
        if AimAssist.Mode == "hold" then
            shouldAim = AimAssist.LockedCharacter ~= nil
        else
            shouldAim = AimAssist.ToggleState
        end
        
        if shouldAim then
            AimAtTarget()
        end
    end
    
    if RageBot.Enabled then
        local shouldRage = false
        
        if RageBot.Mode == "hold" then
            shouldRage = RageBot.LockedCharacter ~= nil
        else
            shouldRage = RageBot.ToggleState
        end
        
        if shouldRage then
            RageAimAtTarget()
        end
    end
    
    if MagnetAim.Enabled and MagnetAim.Holding then
        local target = GetClosestPlayerToCursor()
        if target then
            MagnetPullPlayer(target)
        end
    end
end)

