            local humanoid = char:FindFirstChildOfClass("Humanoid")
            if not humanoid or humanoid.Health <= 0 then continue end
            
            local hitboxPart = GetHitboxPart(char, RageBot.Hitbox)
            
            if hitboxPart then
                local screenPos, onScreen = Camera:WorldToViewportPoint(hitboxPart.Position)
                
                if onScreen then
                    if RageBot.VisibleCheck then
                        local raycastParams = RaycastParams.new()
                        raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
                        raycastParams.FilterDescendantsInstances = {player.Character}
                        local rayResult = workspace:Raycast(cameraPos, (hitboxPart.Position - cameraPos), raycastParams)
                        if rayResult and not rayResult.Instance:IsDescendantOf(char) then
                            continue
                        end
                    end
                    
                    local distanceFromMouse = (Vector2.new(screenPos.X, screenPos.Y) - mousePos).Magnitude
                    
                    if distanceFromMouse < bestDistance then
                        bestDistance = distanceFromMouse
                        bestChar = char
                        bestPart = hitboxPart
                    end
                end
            end
        end
    end
    
    return bestChar, bestPart
end

local function LockRageTarget()
    local targetChar, targetPart = GetRageTargetInFOV()
    if targetChar and targetPart then
        RageBot.LockedCharacter = targetChar
        RageBot.LockedPart = targetPart
        return true
    end
    return false
end

local function ResetRageLock()
    RageBot.LockedCharacter = nil
    RageBot.LockedPart = nil
    RageBot.Stabilizer = {x = 0, y = 0}
end

local function UpdateRageLockedPart()
    if not RageBot.LockedCharacter then return end
    local newPart = GetHitboxPart(RageBot.LockedCharacter, RageBot.Hitbox)
    if newPart then
        RageBot.LockedPart = newPart
    end
end

-- VERSÃO SUPER FORTE - GRUDADO QUE NÃO TREME
local function RageAimAtTarget()
    if not RageBot.LockedCharacter or not RageBot.LockedPart then return end
    
    if not RageBot.LockedPart.Parent then
        UpdateRageLockedPart()
        if not RageBot.LockedPart then
            ResetRageLock()
            if RageBot.Mode == "toggle" then
                RageBot.ToggleState = false
            end
            return
        end
    end
    
    local char = RageBot.LockedCharacter
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not humanoid or humanoid.Health <= 0 then
        ResetRageLock()
        if RageBot.Mode == "toggle" then
            RageBot.ToggleState = false
        end
        return
    end
    
    local screenPos, onScreen = Camera:WorldToViewportPoint(RageBot.LockedPart.Position)
    if not onScreen then return end
    
    local mousePos = UserInputService:GetMouseLocation()
    
    -- Calcula a diferença para o alvo
    local deltaX = screenPos.X - mousePos.X
    local deltaY = screenPos.Y - mousePos.Y
    
    -- Se estiver muito perto, não precisa mover (evita micro-tremores)
    if math.abs(deltaX) < 0.8 and math.abs(deltaY) < 0.8 then
        return
    end
    
    -- Aplica um pequeno fator de smoothing apenas para evitar tremor, mas ainda muito rápido
    local strength = 0.85
    local moveX = deltaX * strength
    local moveY = deltaY * strength
    
    -- Move o mouse instantaneamente mas com estabilização
    if math.abs(moveX) > 0.1 or math.abs(moveY) > 0.1 then
        mousemoverel(moveX, moveY)
    end
end

