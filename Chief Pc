UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if not AimAssist.Enabled then return end
    
    local isKeyMatch = false
    
    if AimAssist.Key == "MB1" and input.UserInputType == Enum.UserInputType.MouseButton1 then
        isKeyMatch = true
    elseif AimAssist.Key == "MB2" and input.UserInputType == Enum.UserInputType.MouseButton2 then
        isKeyMatch = true
    elseif AimAssist.Key == "MB3" and input.UserInputType == Enum.UserInputType.MouseButton3 then
        isKeyMatch = true
    elseif input.KeyCode.Name == AimAssist.Key then
        isKeyMatch = true
    end
    
    if isKeyMatch then
        if AimAssist.Mode == "hold" then
            if not AimAssist.LockedCharacter then
                LockBestTarget()
            end
        else
            if not AimAssist.ToggleState then
                if LockBestTarget() then
                    AimAssist.ToggleState = true
                end
            else
                AimAssist.ToggleState = false
                ResetLock()
            end
        end
    end
end)

