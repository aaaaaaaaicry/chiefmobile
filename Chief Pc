    local function DrawSkeleton(character, data)
        if not character or not esp_flags["Enabled"] or not esp_flags["Skeletons"] then 
            if data then
                HideDrawings(data)
            end
            return 
        end
        
        local bonesList = GetBonesForCharacter(character)
        
        for i, bone in ipairs(bonesList) do
            local originPart = character:FindFirstChild(bone[1])
            local destPart = character:FindFirstChild(bone[2])
            
            if originPart and destPart then
                if not data.drawings[i] then
                    local line = Drawing.new("Line")
                    line.Color = esp_flags["Skeletons_Color"].Color
                    line.Thickness = 1
                    line.Visible = false
                    data.drawings[i] = line
                end
                
                local originPos, originOnScreen = esp:get_screen_pos(originPart.Position)
                local destPos, destOnScreen = esp:get_screen_pos(destPart.Position)
                
                if originOnScreen and destOnScreen then
                    data.drawings[i].Visible = true
                    data.drawings[i].From = Vector2.new(originPos.X, originPos.Y)
                    data.drawings[i].To = Vector2.new(destPos.X, destPos.Y)
                    data.drawings[i].Color = esp_flags["Skeletons_Color"].Color
                else
                    data.drawings[i].Visible = false
                end
            end
        end
    end

